# CryptoWolf OS — Environment Configuration
# Copy this to .env.local and fill in values

# ── Data Sources (all optional — system falls back to mock data if absent) ──
COINGECKO_API_KEY=          # Optional: CoinGecko Pro key for higher rate limits
GITHUB_TOKEN=               # Optional: GitHub PAT for 5000 req/hr (vs 60 unauthed)

# ── Sentry (optional error tracking) ───────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=     # e.g. https://xxx@yyy.ingest.sentry.io/zzz
SENTRY_ORG=
SENTRY_PROJECT=

# ── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_POLL_INTERVAL_MS=20000    # default 20s
NEXT_PUBLIC_DEBUG_LOGGING=false

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0
